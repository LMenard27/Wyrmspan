<h2>Register</h2>

<form method="post" asp-action="Register" style="max-width: 400px;">

    <div class="mb-2">
        <input name="username"
               placeholder="Username"
               maxlength="30"
               class="form-control" />
    </div>

    <div class="mb-2">
        <input name="password"
               type="password"
               placeholder="Password"
               class="form-control" />
    </div>

    <div class="mb-2">
        <input name="pfp"
               placeholder="Profile picture URL (optional)"
               class="form-control" />
    </div>

    <button type="submit" class="btn btn-primary w-100">
        Register
    </button>

</form>

<hr />

<p>
    Already have an account?
    <a asp-controller="Account" asp-action="Login" class="btn btn-link">
        Log in instead
    </a>
</p>