@model ViewProfileViewModel

<div class="d-flex justify-content-center mt-5">

    <div class="card shadow p-4" style="width: 550px; border-radius: 12px;">

        <div class="text-center mb-3">
            <h4 class="mb-0">Dracologist Profile</h4>
        </div>

        <div class="d-flex align-items-center">

            <div class="me-4">
                <img src="@Model.Pfp"
                     class="rounded-circle"
                     width="110"
                     height="110"
                     style="object-fit: cover; border: 2px solid #ccc;" />
            </div>

            <div style="width: 100%">

                <div class="mb-2">
                    <strong>Name:</strong><br />
                    <span>@Model.Username</span>
                </div>

                <div class="mb-2">
                    <strong>Games Played:</strong><br />
                    <span>@Model.Played</span>
                </div>

            </div>

        </div>

        <div class="mt-4">
            <a asp-controller="Account"
               asp-action="EditProfile"
               class="btn btn-primary w-100">
                Edit Profile
            </a>
        </div>

    </div>

</div>