@using MvcMovie.Controllers
@{
    ViewData["Title"] = "Home Page";
}

<style>
    body {
        font-family: Cambria, Cochin, Georgia, Times, 'Times New Roman', serif;
    }

    .top-bar {
        display: flex;
        gap: 20px;
        padding: 10px;
        background: rgb(214, 240, 240);
        border: 2px solid #382316;
        border-radius: 6px;
        box-shadow: 1px 1px 2px rgb(174, 178, 178);
    }

    .resource {
        padding: 5px 10px;
        background: white;
        border: 1px solid #ccc;
        border-radius: 5px;
        box-shadow: inset 1px 1px 2px rgb(174, 178, 178);
    }

    .board {
        height: 500px;
        border: 3px solid #382316;
        border-radius: 6px;
        margin: 20px 0;
        position: relative;
        background-color: rgb(199, 239, 239);
        background:
            linear-gradient(rgba(199,239,239,0.6),rgba(199,239,239,0.6)),
            url('/images/map.PNG');
        background-size: cover;
        background-repeat: no-repeat;
        background-position: center;
    }
    .shop {
        height: 385px;
        border: 2px solid #382316;
        border-radius: 6px;
        margin: 20px 20px;
        padding: 10px;
        position: relative;
        background-color: rgb(199, 239, 239);
        background:
            linear-gradient(rgba(199,239,239,0.6),rgba(199,239,239,0.6)),
            url('/images/map.PNG');
        background-size: cover;
        background-repeat: no-repeat;
        background-position: center;
        right: -13.5%;
    }

    .cavern-slot {
        width: 250px;
        height: 150px;
        background: rgba(121, 166, 166, 0.75);
        border: 2px solid rgb(0, 54, 54);
        border-radius: 6px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .cavern-card {
        width: 100%;
        height: 100%;
    }
    .cavern-container {
        position: absolute;
        top: 10px;
        left: 10%;
        transform: translateX((-25%));
        display: flex;
        flex-direction: column;
        gap: 10px;
        align-items: center;
    }
    .cards-container{
         display: flex;
         flex-direction: row;
    }
    .cavern-row {
        display: flex;
        gap: 10px;
    }

    .action-button {
        margin: 5px;
        background: teal;
        color: white;
        border: 2px solid rgb(0, 54, 54);
        cursor: pointer;
    }

    .hand {
        display: flex;
        flex-direction: column;
        gap: 10px;
        align-items: center;
    }

    .card-row {
        display: flex;
        gap: 10px;
    }

    .card-slot {
        width: 100px;
        height: 140px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgb(238, 233, 224);
        border-radius: 6px;
    }

    .card {
        border: 1px solid rgb(186, 195, 195);
        background: white;
        box-shadow: 1px 1px 2px rgb(174, 178, 178);
        padding: 2px;
        width: 100%;
        height: 100%;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 10px;
    }
    .card img {
        max-height: 75%;
        width: auto;
        object-fit: contain;
    }
    .card-text {
        font-size: 12px;
        font-weight: bold;
        margin-top: 2px;
        color: #333;
    }
</style>

<div class="text-center">
    <h1 class="display-4">Wyrmspan</h1>
    <button id="initBtn">Initialize Game Board</button>

    <script>
        document.getElementById("initBtn").addEventListener("click", function () {
            fetch("http://localhost:5012/Game/Initialize", {
                method: "GET"
            })
            .then(response => response.text())
            .then(data => {
                console.log(data);
            })
            .catch(error => {
                console.error("Error:", error);
            });
        });
    </script>

<!-- 🔝 RESOURCE BAR -->
<div class="top-bar">
    <div class="resource">Coins:</div>
    <div class="resource">Meat:</div>
    <div class="resource">Gold:</div>
    <div class="resource">Amethyst:</div>
    <div class="resource">Milk:</div>
    <div class="resource">Eggs:</div>

    <!-- Example action buttons -->
    <form method="post" asp-action="Excavate">
        <button class="action-button">Excavate</button>
    </form>

    <form method="post" asp-action="Explore">
        <button class="action-button">Explore</button>
    </form>

    <form method="post" asp-action="Entice">
        <button class="action-button">Entice</button>
    </form>
</div>

<!-- 🗺️ BOARD -->
<div class="board">
    <div class ="cavern-container">
        @for (int i =0; i<3; i++){
            <div class ="cavern-row">
            @for (int j=0; j < 4; j++){
                <div class="cavern-slot">
                </div>
            }
            </div>
        }
    </div>

</div>

<!-- 🃏 PLAYER HAND -->
<div class="cards-container">
    <div class="hand">
        <!-- DRAGON CARDS -->
        <div>
            <h3>Dragons</h3>
            <div class="card-row">
                @for (int i = 0; i < 7; i++)
                {
                    <div class="card-slot">
                        @if (i < 3) 
                        {
                            <div class="card">
                                @if(i == 0) {
                                    <img src = "/images/quetzacoatlColour.PNG" alt = "Red, yellow, green Quetzacoatl Dragon" />
                                }
                                @if(i == 1) {
                                    <img src = "/images/blueDragon.PNG" alt = "Blue eastern dragon" />
                                }
                                @if(i == 2) {
                                    <img src = "/images/redDragon.PNG" alt = "Red and yellow eastern dragon" />
                                }
                                <div class="card-text">QueztalCoatl</div>
                                <div class="card-text">Description</div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>

        <!-- CAVE CARDS -->
        <div>
            <h3>Caves</h3>
            <div class="card-row">
                @for (int i = 0; i < 7; i++)
                {
                    <div class="card-slot">
                        @if (i < 3)
                        {
                            <div class="card">
                                @if(i==0){
                                    <img src = "/images/caveCentral.PNG" alt= "Cave"/>
                                }
                                @if(i==1){
                                    <img src = "/images/caveCorner.PNG" alt="Cave"/>
                                }
                                <div class = "card-text">Cave</div>
                                <div class="card-text">Description</div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
    <div class ="shop">
        <div class="hand">
            <div> 
                <h3>Dragon Shop</h3>
                <div class="card-row">
                    @for (int i = 0; i < 3; i++)
                    {
                        <div class="card-slot">
                            @if (i < 3) 
                            {
                                <div class="card">
                                    @if(i == 0) {
                                        <img src = "/images/quetzacoatlColour.PNG" alt = "Red, yellow, green Quetzacoatl Dragon" />
                                    }
                                    @if(i == 1) {
                                        <img src = "/images/blueDragon.PNG" alt = "Blue eastern dragon" />
                                    }
                                    @if(i == 2) {
                                        <img src = "/images/redDragon.PNG" alt = "Red and yellow eastern dragon" />
                                    }
                                    <div class="card-text">QueztalCoatl</div>
                                    <div class="card-text">Description</div>
                                </div>
                            }
                        </div>
                    }
                </div>
                <h3>Cave Shop</h3>
                <div class="card-row">
                    @for (int i = 0; i < 3; i++)
                    {
                        <div class="card-slot">
                            @if (i < 3)
                            {
                                <div class="card">
                                    @if(i==0){
                                        <img src = "/images/caveCentral.PNG" alt= "Cave"/>
                                    }
                                    @if(i==1){
                                        <img src = "/images/caveCorner.PNG" alt="Cave"/>
                                    }
                                    <div class = "card-text">Cave</div>
                                    <div class="card-text">Description</div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
    
</div>
