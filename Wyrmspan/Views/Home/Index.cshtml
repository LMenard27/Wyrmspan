@using MvcMovie.Controllers
@{
    ViewData["Title"] = "Home Page";
}

<div class="text-center">

<!-- 🔝 RESOURCE BAR -->
<div class="top-bar">
    <div class="resource", id="coinCounter">Coins:</div>
    <div class="resource", id="meatCounter">Meat:</div>
    <div class="resource", id="goldCounter">Gold:</div>
    <div class="resource", id="amethystCounter">Amethyst:</div>
    <div class="resource", id="milkCounter">Milk:</div>
    <div class="resource", id="eggCounter">Eggs:</div>
    <div class="resource", id="reputationCounter">Reputation:</div>

    <!-- Example action buttons -->
    <button class="action-button" id="excavateBtn">Excavate</button>

    <button class="action-button" id="exploreBtn">Explore</button>

    <button class="action-button" id="enticeBtn">Entice</button>

    <button class="cancel-button" id="skipBtn">Skip</button>

    <div class="resource", id="playerIndicator">Turn:</div>
    <div class="resource", id="playerIndicator2">Acting:</div>
</div>

<!-- 🗺️ BOARD -->
<div class="board">
    <div class ="cavern-container">
        @for (int i =0; i<3; i++){
            @if(i==0){
                <div class="cavern-text" >Crimson Cavern</div>
            } else if (i == 1){
                <div class="cavern-text" >Golden Grotto</div>
            } else {
                <div class="cavern-text">Amethyst Abyss</div>
            }
            <div class ="cavern-row">
            @for (int j=0; j < 4; j++){
                <div class="cavern-slot", id="@($"cavern-slot-{i}-{j}")">
                </div>
            }
            </div>
        }
    </div>

</div>

<!-- 🃏 PLAYER HAND -->
<div class="cards-container">
    <div class="hand">
        <!-- DRAGON CARDS -->
        <div>
            <h3>Dragons</h3>
            <div class="card-row">
                @for (int i = 0; i < 7; i++)
                {
                    <div class="card-slot">
                        <div class="card">
                            <div class="cost-text", name="dragonCost">Free</div>
                            <div class="card-text", name="dragonName">QueztalCoatl</div>
                            <img src = "/images/quetzacoatlColour.png" alt = "Red, yellow, green Quetzacoatl Dragon" />
                            <div class="card-text", name="dragonDesc">Description</div>
                        </div>
                    </div>
                }
            </div>
        </div>

        <!-- CAVE CARDS -->
        <div>
            <h3>Caves</h3>
            <div class="card-row">
                @for (int i = 0; i < 7; i++)
                {
                    <div class="card-slot">
                        <div class="card">
                            <img src = "/images/caveCentral.png" alt= "Cave"/>
                            <div class="card-text", name="caveDesc">Description</div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
    <div class ="shop">
        <div class="hand">
            <div> 
                <h3>Dragon Shop</h3>
                <div class="card-row">
                    @for (int i = 0; i < 3; i++)
                    {
                        <div class="card-slot">
                            <div class="card">
                                <div class="cost-text", name="shopDragonCost">Free</div>
                                <div class="card-text", name="shopDragonName">QueztalCoatl</div>
                                <img src = "/images/blueDragon.png" alt = "Blue Eastern Dragon" />
                                <div class="card-text", name="shopDragonDesc">Description</div>
                            </div>
                        </div>
                    }
                </div>
                <h3>Cave Shop</h3>
                <div class="card-row">
                    @for (int i = 0; i < 3; i++)
                    {
                        <div class="card-slot">
                            <div class="card">
                                <img src = "/images/caveCorner.png" alt= "Cave"/>
                                <div class="card-text", name="shopCaveDesc">Description</div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
    
</div>

<button id="rulesBtn">How To Play</button>

<div id=chooseOneModal class="modal">
    <div class="modal-content">
        <p id="oneModalDynamicText">No Description Given</p>

        <div id="oneModalDynamicContent"></div>

        <div class="modal-actions">
            <button class="cancel-button" id="oneModalClose">Close</button>
            <button class="skip-button" id="oneModalSkip">Skip</button>
            <button class="action-button" id="oneModalSubmit">Submit</button>
        </div>
    </div>
</div>

<div id=chooseTwoModal class="modal">
    <div class="modal-content">
        <p id="twoModalDynamicText">No Description Given</p>

        <div id="twoModalDynamicContent"></div>

        <div class="modal-actions">
            <button class="cancel-button" id="twoModalClose">Close</button>
            <button class="skip-button" id="twoModalSkip">Skip</button>
            <button class="action-button" id="twoModalSubmit">Submit</button>
        </div>
    </div>
</div>

<body onload="updateDisplay()"> </body>