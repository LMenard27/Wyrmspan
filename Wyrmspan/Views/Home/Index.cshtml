@using MvcMovie.Controllers
@{
    ViewData["Title"] = "Home Page";
}

<div class="text-center">
    <h1 class="display-4">Wyrmspan</h1>
    <button id="initBtn">Initialize Game Board</button>

    <script>
        document.getElementById("initBtn").addEventListener("click", function () {
            fetch("http://localhost:5012/Game/Initialize", {
                method: "GET"
            })
            .then(response => response.text())
            .then(data => {
                console.log(data);
            })
            .catch(error => {
                console.error("Error:", error);
            });
        });
    </script>



</div>

@using Wyrmspan.Models 
@model Player

@{
    ViewData["Title"] = Model.getName() + "'s Mat";
    var resources = Model.getResources();
    var dragonHand = Model.getDragonHand();
    var caveHand = Model.getCaveHand();
    
    var playerMat = Model.getMat();
    var caverns = playerMat.getCaverns(); 
    
    var cavernNames = new string[] { "CRIMSON CAVERN", "GOLDEN GROTTO", "AMETHYST ABYSS" };
    var cavernColors = new string[] { "#ffe6e6", "#fff4e6", "#f4e6ff" };
}

<style>
    .game-board { font-family: sans-serif; background: #f4f4f4; padding: 20px; display: flex; flex-direction: column; gap: 20px; }
    
    /* Resources */
    .resource-bar { display: flex; justify-content: space-around; background: #2b7a78; color: white; padding: 15px; border-radius: 5px; font-weight: bold; }
    
    /* Rows & Actions */
    .mat-row { display: flex; align-items: center; padding: 10px; border-radius: 5px; min-height: 150px; gap: 10px; border: 1px solid #ccc; }
    .row-title { width: 120px; font-weight: bold; text-align: center; }
    .action-btn { background: #38b000; color: white; border: 2px solid #007200; width: 50px; height: 50px; border-radius: 5px; cursor: pointer; }

    /* Slots and Cards */
    .slot { width: 100px; height: 140px; border: 2px dashed #999; display: flex; flex-direction: column; align-items: center; justify-content: center; background: #fff; font-size: 0.7rem; text-align: center; padding: 5px; }
    .slot.occupied { border-style: solid; border-color: #333; }
    .slot.empty { color: #aaa; }

    /* Hand */
    .hand-container { background: #333; padding: 15px; border-radius: 5px; color: white; }
    .hand-section { display: flex; gap: 10px; padding-bottom: 10px; overflow-x: auto; }
    .card-hand { width: 110px; height: 150px; background: white; color: black; border-radius: 4px; padding: 5px; font-size: 0.8rem; display: flex; flex-direction: column; }
    .card-hand.empty-slot { background: #555; border: 1px dashed #888; color: #999; }
</style>

<div class="game-board">

    <div class="resource-bar">
        <span>🪙 @resources[Resources.Coins]</span>
        <span>🥛 @resources[Resources.Milk]</span>
        <span>🥩 @resources[Resources.Meat]</span>
        <span>💎 @resources[Resources.Amethyst]</span>
        <span>🧱 @resources[Resources.Gold]</span>
        <span>🥚 @resources[Resources.Eggs] / @playerMat.getTotEggCapacity()</span>
        <span>⭐ @resources[Resources.Reputation]</span>
    </div>

    <div class="player-mat" style="display: flex; flex-direction: column; gap: 10px;">
        @for (int i = 0; i < caverns.Length; i++)
        {
            var cavern = caverns[i];
            var rowDragons = cavern.getDragons();
            var rowCaves = cavern.getCaves();

            <div class="mat-row" style="background-color: @cavernColors[i];">
                <div class="row-title">@cavernNames[i]</div>
                
                <button class="action-btn" title="Explores: @cavern.getExploreCount()">Explore</button>

                @* Render the 4 spaces per cavern *@
                @for (int s = 0; s < 4; s++)
                {
                    bool hasDragon = rowDragons[s] != null;
                    bool hasCave = rowCaves[s] != null && rowCaves[s].getId() != -1;

                    <div class="slot @(hasDragon || hasCave ? "occupied" : "empty")">
                        @if (hasDragon)
                        {
                            <strong>@rowDragons[s].getName()</strong>
                            <span>VP: @rowDragons[s].getVP()</span>
                        }
                        else if (hasCave)
                        {
                            <span style="color: brown;">Cave Area</span>
                            <small>ID: @rowCaves[s].getId()</small>
                        }
                        else
                        {
                            <span>Empty Space</span>
                        }
                    </div>
                    
                    @* Green Action Buttons between slots as requested *@
                    if (s < 3) { <button class="action-btn">Action</button> }
                }
            </div>
        }
    </div>

    <div class="hand-container">
        <h4>Dragons (@dragonHand.Count / 7)</h4>
        <div class="hand-section">
            @for (int i = 0; i < 7; i++)
            {
                if (i < dragonHand.Count)
                {
                    <div class="card-hand">
                        <strong>@dragonHand[i].getName()</strong>
                        <hr />
                        <small>Size: @dragonHand[i].getSize()</small>
                        <small>VP: @dragonHand[i].getVP()</small>
                    </div>
                }
                else
                {
                    <div class="card-hand empty-slot">Empty</div>
                }
            }
        </div>

        <h4>Caves (@caveHand.Count / 7)</h4>
        <div class="hand-section">
            @for (int i = 0; i < 7; i++)
            {
                if (i < caveHand.Count)
                {
                    <div class="card-hand">
                        <strong>Cave Card</strong>
                        <small>ID: @caveHand[i].getId()</small>
                    </div>
                }
                else
                {
                    <div class="card-hand empty-slot">Empty</div>
                }
            }
        </div>
    </div>
</div>
