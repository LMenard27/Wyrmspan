@using MvcMovie.Controllers
@{
    ViewData["Title"] = "Home Page";
}

<div class="text-center">
    <h1 class="display-4">Wyrmspan</h1>
    <button id="initBtn">Initialize Game Board</button>

    <script>
        document.getElementById("initBtn").addEventListener("click", function () {
            fetch("http://localhost:5012/Game/Initialize", {
                method: "GET"
            })
            .then(response => response.text())
            .then(data => {
                console.log(data);
            })
            .catch(error => {
                console.error("Error:", error);
            });
        });
    </script>



</div>

@model GameController

<style>
    body {
        font-family: Arial;
    }

    .top-bar {
        display: flex;
        gap: 20px;
        padding: 10px;
        background: #eee;
        border-bottom: 2px solid #ccc;
    }

    .resource {
        padding: 5px 10px;
        background: white;
        border: 1px solid #ccc;
        border-radius: 5px;
    }

    .board {
        height: 300px;
        border: 2px solid #999;
        margin: 20px 0;
        position: relative;
    }

    .action-button {
        position: absolute;
        padding: 10px;
        background: teal;
        color: white;
        border: none;
        cursor: pointer;
    }

    .hand {
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .card-row {
        display: flex;
        gap: 10px;
    }

    .card-slot {
        width: 100px;
        height: 140px;
        border: 2px dashed #aaa;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #fafafa;
    }

    .card {
        border: 1px solid #333;
        background: white;
        padding: 5px;
        text-align: center;
        width: 100%;
        height: 100%;
    }
</style>

<!-- 🔝 RESOURCE BAR -->
<div class="top-bar">
    
    <div class="resource">Gold: </div>
    <div class="resource">Milk: @Model.</div>
    <div class="resource">Meat: @Model.Meat</div>
    <div class="resource">Crystal: @Model.Crystal</div>
    <div class="resource">Gems: @Model.Gems</div>
    <div class="resource">Eggs: @Model.Eggs</div>
</div>

<!-- 🗺️ BOARD -->
<div class="board">

    <!-- Example action buttons -->
    <form method="post" asp-action="Excavate">
        <button class="action-button" style="top:20px; left:50px;">Excavate</button>
    </form>

    <form method="post" asp-action="Explore">
        <button class="action-button" style="top:100px; left:150px;">Explore</button>
    </form>

    <form method="post" asp-action="Mine">
        <button class="action-button" style="top:200px; left:250px;">Mine</button>
    </form>

</div>

<!-- 🃏 PLAYER HAND -->
<div class="hand">

    <!-- DRAGON CARDS -->
    <div>
        <h3>Dragons</h3>
        <div class="card-row">
            @for (int i = 0; i < 7; i++)
            {
                <div class="card-slot">
                    @if (i < Model.DragonCards.Count)
                    {
                        <div class="card">
                            @Model.DragonCards[i].Name
                        </div>
                    }
                </div>
            }
        </div>
    </div>

    <!-- CAVE CARDS -->
    <div>
        <h3>Caves</h3>
        <div class="card-row">
            @for (int i = 0; i < 7; i++)
            {
                <div class="card-slot">
                    @if (i < Model.CaveCards.Count)
                    {
                        <div class="card">
                            @Model.CaveCards[i].Name
                        </div>
                    }
                </div>
            }
        </div>
    </div>

</div>
